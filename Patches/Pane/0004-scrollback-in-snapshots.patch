diff --git a/Sources/pane/PaneProtocol.swift b/Sources/pane/PaneProtocol.swift
index a283f6d..92ef307 100644
--- a/Sources/pane/PaneProtocol.swift
+++ b/Sources/pane/PaneProtocol.swift
@@ -98,6 +98,8 @@ struct PaneTerminalSnapshot: Codable {
     var cursorY: Int
     var isAlternate: Bool
     var lines: [[PaneCell]]
+    /// Scrollback history, oldest line first. Empty when unavailable.
+    var scrollbackLines: [[PaneCell]]
 }
 
 struct PaneTerminalDelta: Codable {
@@ -336,6 +338,15 @@ extension PaneTerminalSnapshot: PaneBinaryCodable {
                 cell.write(to: &writer)
             }
         }
+        // Scrollback: written after screen lines for backward compatibility.
+        // Old clients that stop reading after `lines` will simply not see scrollback.
+        writer.writeUInt16(UInt16(scrollbackLines.count))
+        for line in scrollbackLines {
+            writer.writeUInt16(UInt16(line.count))
+            for cell in line {
+                cell.write(to: &writer)
+            }
+        }
     }
 
     init(from reader: inout PaneBinaryReader) throws {
@@ -356,6 +367,23 @@ extension PaneTerminalSnapshot: PaneBinaryCodable {
             }
             lines.append(line)
         }
+        // Scrollback is optional — old servers won't send this field.
+        if reader.remaining >= 2 {
+            let scrollbackCount = Int(try reader.readUInt16())
+            scrollbackLines = []
+            scrollbackLines.reserveCapacity(scrollbackCount)
+            for _ in 0..<scrollbackCount {
+                let cellCount = Int(try reader.readUInt16())
+                var line: [PaneCell] = []
+                line.reserveCapacity(cellCount)
+                for _ in 0..<cellCount {
+                    line.append(try PaneCell(from: &reader))
+                }
+                scrollbackLines.append(line)
+            }
+        } else {
+            scrollbackLines = []
+        }
     }
 }
 
