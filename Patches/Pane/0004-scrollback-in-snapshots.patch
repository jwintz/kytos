diff --git a/Sources/pane/PaneTerminalSession.swift b/Sources/pane/PaneTerminalSession.swift
index ad9ad74..465ea2d 100644
--- a/Sources/pane/PaneTerminalSession.swift
+++ b/Sources/pane/PaneTerminalSession.swift
@@ -183,13 +183,32 @@ final class PaneTerminalSession: Terminal, LocalProcessDelegate {
         let lines = (0..<rows).map { row in
             buildLine(row: row)
         }
+        // Collect up to 500 scrollback lines.
+        // buffer.yBase counts lines pushed into scrollback (capped at scrollbackSize=500
+        // after which linesTop increments instead to track ring rotation).
+        // getScrollInvariantLine(row:) valid range is linesTop..(linesTop+lines.count-1),
+        // so the oldest surviving scrollback line is at absolute row `linesTop`,
+        // and newest scrollback is at `linesTop + yBase - 1`.
+        let (sbStart, sbCount) = getScrollbackInfo()
+        let scrollbackCount = min(sbCount, 500)
+        var scrollbackLines: [[PaneCell]] = []
+        if scrollbackCount > 0 {
+            scrollbackLines.reserveCapacity(scrollbackCount)
+            // startIdx accounts for linesTop (ring rotation offset) so getScrollInvariantLine
+            // doesn't return nil after the scrollback ring fills past its 500-line capacity.
+            let startIdx = sbStart + (sbCount - scrollbackCount)
+            for i in 0..<scrollbackCount {
+                if let bufferLine = getScrollInvariantLine(row: startIdx + i) {
+                    scrollbackLines.append(buildLineFromBuffer(bufferLine))
+                }
+            }
+        }
         return PaneTerminalSnapshot(
             cols: cols,
             rows: rows,
             cursorX: cursor.x,
             cursorY: cursor.y,
             isAlternate: isCurrentBufferAlternate,
-            lines: lines
+            lines: lines,
+            scrollbackLines: scrollbackLines
         )
     }
 
@@ -227,4 +245,21 @@ final class PaneTerminalSession: Terminal, LocalProcessDelegate {
         }
         return cells
     }
+
+    /// Builds a PaneCell array directly from a BufferLine (used for scrollback rows
+    /// which are not accessible via getCharData / getLine due to negative-row rejection).
+    private func buildLineFromBuffer(_ bufferLine: BufferLine) -> [PaneCell] {
+        var cells: [PaneCell] = []
+        cells.reserveCapacity(cols)
+        for col in 0..<cols {
+            let data = bufferLine[col]
+            let character = String(getCharacter(for: data))
+            cells.append(PaneCell(
+                char: character,
+                width: data.width,
+                attribute: PaneAttribute(data.attribute)
+            ))
+        }
+        return cells
+    }
 }
 
